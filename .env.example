APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SEO_SITE_NAME="Kampanye Calon Kepala Desa Sumber Makmur"
SEO_DESCRIPTION="Website resmi kampanye calon kepala desa Sumber Makmur"
SEO_DEFAULT_IMAGE=/images/og-default.jpg
SEO_TWITTER_HANDLE=@calondesa
SEO_FB_APP_ID=
SEO_AUTHOR="Tim Kampanye Desa Sumber Makmur"

# === SEO: Sitemap ===
SEO_SITEMAP_HOME_PRIORITY=1.0
SEO_SITEMAP_HOME_FREQ=daily
SEO_SITEMAP_LIST_PRIORITY=0.9
SEO_SITEMAP_LIST_FREQ=daily
SEO_SITEMAP_STATIC_PRIORITY=0.8
SEO_SITEMAP_STATIC_FREQ=weekly
SEO_SITEMAP_DETAIL_PRIORITY=0.7
SEO_SITEMAP_DETAIL_FREQ=weekly
SEO_SITEMAP_LOW_PRIORITY=0.6
SEO_SITEMAP_LOW_FREQ=monthly

# === SEO: Robots.txt ===
SEO_ROBOTS_CRAWL_DELAY=10
SEO_ROBOTS_DISALLOW="/admin/,/login/"

# === SEO: Open Graph / Twitter ===
SEO_OG_IMAGE_WIDTH=1200
SEO_OG_IMAGE_HEIGHT=630
SEO_TWITTER_CARD_TYPE=summary_large_image
SEO_OG_LOCALE=id_ID

# === SEO: Meta Robots Default ===
# Use "noindex, nofollow" for staging/pre-production
SEO_DEFAULT_ROBOTS="index, follow"

# === SEO: Helper Defaults ===
SEO_META_DESC_LENGTH=160
SEO_OG_STORAGE_PATH=storage/

# === CDN / Assets ===
SEO_GOOGLE_FONTS_URL="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Nunito:wght@400;500;600;700&display=swap"
ALPINEJS_CDN_URL="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js"

# === SEO: Page-level (List Pages) ===
# Kosongkan untuk menggunakan default dari config/seo.php
SEO_PAGE_BERANDA_TITLE=Beranda
SEO_PAGE_BERANDA_DESCRIPTION=
SEO_PAGE_BERANDA_KEYWORDS=

SEO_PAGE_BERITA_TITLE="Berita & Kegiatan"
SEO_PAGE_BERITA_DESCRIPTION=
SEO_PAGE_BERITA_KEYWORDS=

SEO_PAGE_CATATAN_TITLE="Catatan Harian"
SEO_PAGE_CATATAN_DESCRIPTION=
SEO_PAGE_CATATAN_KEYWORDS=

SEO_PAGE_PROFIL_TITLE="Profil Calon"
SEO_PAGE_PROFIL_DESCRIPTION=
SEO_PAGE_PROFIL_KEYWORDS=

SEO_PAGE_VISI_MISI_TITLE="Visi & Misi"
SEO_PAGE_VISI_MISI_DESCRIPTION=
SEO_PAGE_VISI_MISI_KEYWORDS=

SEO_PAGE_PROGRAM_TITLE="Program Kerja"
SEO_PAGE_PROGRAM_DESCRIPTION=
SEO_PAGE_PROGRAM_KEYWORDS=

SEO_PAGE_TRANSPARANSI_TITLE="Transparansi & Laporan"
SEO_PAGE_TRANSPARANSI_DESCRIPTION=
SEO_PAGE_TRANSPARANSI_KEYWORDS=

SEO_PAGE_GALERI_TITLE="Galeri Kegiatan"
SEO_PAGE_GALERI_DESCRIPTION=
